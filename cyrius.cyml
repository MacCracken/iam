[package]
name = "iam"
version = "${file:VERSION}"
description = "iam — fastfetch-equivalent system info display. Pure inverse of whoami: whoami says who the user is, iam says what the system is. Thin presentation over the mihi probe library."
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.0.1"

[build]
entry = "src/main.cyr"
test = "src/test.cyr"
output = "iam"

[deps]
# Union of iam's own needs and what mihi+ai-hwaccel's bundles
# reference. Even though iam doesn't call the GPU probes until M3,
# `include "lib/mihi.cyr"` pulls in gpu.cyr which references
# ai-hwaccel symbols — the parser needs the full chain present;
# DCE drops unused code from the linked binary.
stdlib = [
    "string", "fmt", "alloc", "io", "vec", "str", "slice",
    "syscalls", "assert", "agnosys", "fs", "tagged", "process",
    "fnptr", "thread", "freelist", "hashmap", "ct", "json", "bench",
]

# mihi: the system-info probe library. Every displayed line routes
# through a mihi_* probe — `iam` is the presentation layer, mihi
# owns the probes (CLAUDE.md: "Probe via mihi, never inline").
[deps.mihi]
git = "https://github.com/MacCracken/mihi.git"
tag = "0.7.0"
modules = ["dist/mihi.cyr"]

# ai-hwaccel: pulled in because mihi/gpu.cyr inside dist/mihi.cyr
# references registry_detect_no_exec / profile_* / FAMILY_CPU. Pin
# matches mihi 0.7.0's transitive (mihi's own [deps.ai-hwaccel]).
[deps.ai-hwaccel]
git = "https://github.com/MacCracken/ai-hwaccel.git"
tag = "2.2.6"
modules = ["dist/ai-hwaccel.cyr"]
